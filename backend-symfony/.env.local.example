# Copiez ce fichier en .env.local et adaptez les valeurs

# Base de données XAMPP MySQL
DATABASE_URL="mysql://root:@127.0.0.1:3306/Gestion_Documents?serverVersion=8.2.12&charset=utf8mb4"

# Email SMTP (Gmail avec mot de passe d'application)
MAILER_DSN=smtp://votre-email@gmail.com:votre-mot-de-passe-app@smtp.gmail.com:587?encryption=tls
MAIL_FROM_ADDRESS=votre-email@gmail.com
MAIL_FROM_NAME="Gestion Documents"

# JWT
JWT_PASSPHRASE=VotrePassphraseSuperSecrete256BitsMinimum

# CORS (permettre Angular)
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
